# Persistência
NEXT_PUBLIC_PERSISTENCE=local

# IA — OpenRouter (gateway único: uma chave, qualquer modelo).
# Fallback do servidor quando o usuário não digita a chave em Ajustes → IA.
OPENROUTER_API_KEY=

# IA — Gemini, usado só para embeddings da memória (cota grátis separada).
GEMINI_API_KEY=

# Supabase (opcional - quando ativar)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Email transacional (opcional - quando ativar)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Google Calendar (opcional - quando ativar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
